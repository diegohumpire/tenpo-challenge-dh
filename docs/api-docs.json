                                "schema": { "type": "string" }
                            },
                            "X-RateLimit-Remaining": {
                                "description": "Remaining requests in the current window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 2 }
                            },
                            "X-RateLimit-Limit": {
                                "description": "Maximum requests allowed per time window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 3 }
                            }
                        },
                        "content": { "*/*": { "schema": { "$ref": "#/components/schemas/AuditLogDetailResponse" } } }
                    },
                    "404": {
                        "description": "Audit log not found",
                        "headers": {
                            "X-Transactional-Id": {
                                "description": "Echoed correlation ID for distributed tracing",
                                "style": "simple",
                                "schema": { "type": "string" }
                            },
                            "X-RateLimit-Remaining": {
                                "description": "Remaining requests in the current window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 2 }
                            },
                            "X-RateLimit-Limit": {
                                "description": "Maximum requests allowed per time window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 3 }
                            }
                        },
                        "content": {
                            "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } }
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "headers": {
                            "X-RateLimit-Remaining": {
                                "description": "Remaining requests in the current window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 0 }
                            },
                            "Retry-After": {
                                "description": "Seconds to wait before making another request",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 58 }
                            },
                            "X-RateLimit-Reset": {
                                "description": "Unix timestamp (seconds) when the rate limit window resets",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 1714000060 }
                            },
                            "X-RateLimit-Limit": {
                                "description": "Maximum requests allowed per time window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 3 }
                            }
                        },
                        "content": {
                            "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } }
                        }
                    }
                }
            }
        },
        "/api/v1/audit-logs/users/{userId}": {
            "get": {
                "tags": ["Audit Logs"],
                "summary": "Get audit logs by user ID",
                "description": "Returns all fields for a given user ID, excluding GET_AUDIT_LOGS entries.",
                "operationId": "getByUserId",
                "parameters": [
                    {
                        "name": "X-Transactional-Id",
                        "in": "header",
