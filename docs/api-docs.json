                                "style": "simple",
                                "schema": { "type": "integer", "example": 3 }
                            }
                        },
                        "content": {
                            "*/*": { "schema": { "$ref": "#/components/schemas/PageResponseAuditLogDetailResponse" } }
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded",
                        "headers": {
                            "X-RateLimit-Remaining": {
                                "description": "Remaining requests in the current window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 0 }
                            },
                            "Retry-After": {
                                "description": "Seconds to wait before making another request",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 58 }
                            },
                            "X-RateLimit-Reset": {
                                "description": "Unix timestamp (seconds) when the rate limit window resets",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 1714000060 }
                            },
                            "X-RateLimit-Limit": {
                                "description": "Maximum requests allowed per time window",
                                "style": "simple",
                                "schema": { "type": "integer", "example": 3 }
                            }
                        },
                        "content": {
                            "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } }
                        }
                    }
                }
            }
        },
